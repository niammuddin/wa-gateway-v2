# Copy this file to .env and replace every placeholder before running locally.
# Docker Compose values
POSTGRES_DB=wagateway
POSTGRES_USER=wagateway
POSTGRES_PASSWORD=replace-with-a-strong-database-password
PORT=:3000
DATABASE_URL=postgresql://wagateway:wagateway@localhost:5432/wagateway?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
WEBHOOK_ENCRYPTION_KEY=replace-with-a-32-byte-or-longer-secret
# Generate unique values; never commit the resulting .env file.
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me
AUTH_DIR=./auth_sessions
