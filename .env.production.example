# Copy to .env.production and replace every value. Never commit the result.

POSTGRES_DB=wagateway
POSTGRES_USER=wagateway
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Published host port. Keep PostgreSQL and Redis internal to Docker.
GATEWAY_PORT=3000

JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
WEBHOOK_ENCRYPTION_KEY=replace-with-a-long-random-secret
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Optional timezone for container logs.
TZ=Asia/Jakarta
